<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.tianshi.songzeyang.mapper.SalaryMapper">

    <!-- 结果集映射 -->
    <resultMap id="SalaryResultMap" type="Salary">
        <id column="id" property="id"/>
        <result column="employee_id" property="employeeId"/>
        <result column="salary_amount" property="salaryAmount"/>
        <result column="pay_date" property="payDate"/>
        <result column="pay_status" property="payStatus"/>
    </resultMap>

    <!-- 新增薪资记录 -->
    <insert id="insert" parameterType="Salary" useGeneratedKeys="true" keyProperty="id">
        INSERT INTO salary (employee_id, salary_amount, pay_date, pay_status)
        VALUES (#{employeeId}, #{salaryAmount}, #{payDate}, #{payStatus})
    </insert>

    <!-- 根据ID删除薪资记录 -->
    <delete id="deleteById" parameterType="Integer">
        DELETE FROM salary WHERE id = #{id}
    </delete>

    <!-- 动态更新：仅修改非空属性 -->
    <update id="update" parameterType="Salary">
        UPDATE salary
        <set>
            <if test="employeeId != null">
                employee_id = #{employeeId},
            </if>
            <if test="salaryAmount != null">
                salary_amount = #{salaryAmount},
            </if>
            <if test="payDate != null">
                pay_time = #{payDate},
            </if>
            <if test="payStatus != null">
                pay_status = #{payStatus}
            </if>
        </set>
        WHERE id = #{id}
    </update>

    <!-- 查询所有薪资记录 -->
    <select id="selectAll" resultMap="SalaryResultMap">
        SELECT * FROM salary ORDER BY id ASC
    </select>

    <!-- 多条件动态查询：仅拼接非空条件 -->
    <select id="selectMultiCondition" parameterType="Salary" resultMap="SalaryResultMap">
        SELECT * FROM salary
        <where>
            <if test="id != null">
                AND id = #{id}
            </if>
            <if test="employeeId != null">
                AND employee_id = #{employeeId}
            </if>
            <if test="salaryAmount != null">
                AND salary_amount = #{salaryAmount}
            </if>
            <if test="payDate != null">
                AND pay_date = #{payDate}
            </if>
            <if test="payStatus != null">
                AND pay_status = #{payStatus}
            </if>
        </where>
    </select>

</mapper>