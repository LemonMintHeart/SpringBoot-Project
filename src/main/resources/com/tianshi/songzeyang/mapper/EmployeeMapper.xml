<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.tianshi.songzeyang.mapper.EmployeeMapper">

    <!-- 结果映射 -->
    <resultMap id="EmployeeResultMap" type="Employee">
        <id column="id" property="id"/>
        <result column="emp_no" property="empNo"/>
        <result column="emp_name" property="empName"/>
        <result column="gender" property="gender"/>
        <result column="phone" property="phone"/>
        <result column="email" property="email"/>
        <result column="department_id" property="departmentId"/>
        <result column="status" property="status"/>
        <result column="hire_date" property="hireDate"/>
    </resultMap>

    <!-- 查询所有员工 -->
    <select id="selectAll" resultMap="EmployeeResultMap">
        SELECT id, emp_no, emp_name, gender, phone, email, department_id, status, hire_date
        FROM employee
        ORDER BY id
    </select>

    <!-- 模糊查询 -->
    <select id="selectByName" resultMap="EmployeeResultMap">
        SELECT id, emp_no, emp_name, gender, phone, email, department_id, status, hire_date
        FROM employee
        WHERE emp_name LIKE CONCAT('%', #{empName}, '%')
        ORDER BY id
    </select>

    <!-- 批量删除 -->
    <delete id="deleteBatch">
        DELETE FROM employee
        WHERE id IN
        <foreach collection="ids" item="id" open="(" separator="," close=")">
            #{id}
        </foreach>
    </delete>

</mapper>