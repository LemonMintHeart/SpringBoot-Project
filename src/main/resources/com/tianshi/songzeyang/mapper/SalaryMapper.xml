<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.tianshi.songzeyang.mapper.SalaryMapper">
    <!-- 结果集映射 (假设你已将 pay_time 改回 pay_date，若未改请自行换回) -->
    <resultMap id="SalaryResultMap" type="Salary">
        <id column="id" property="id"/>
        <result column="employee_id" property="employeeId"/>
        <result column="salary_amount" property="salaryAmount"/>
        <result column="pay_date" property="payDate"/>
        <result column="pay_status" property="payStatus"/>
    </resultMap>

    <!-- 新增薪资记录 -->
    <insert id="insert" useGeneratedKeys="true" keyProperty="salary.id">
        INSERT INTO salary (employee_id, salary_amount, pay_date, pay_status)
        VALUES (#{salary.employeeId}, #{salary.salaryAmount}, #{salary.payDate}, #{salary.payStatus})
    </insert>

    <!-- 根据ID删除薪资记录 -->
    <delete id="deleteById">
        DELETE FROM salary WHERE id = #{id}
    </delete>

    <!-- 【新增】批量删除薪资记录 -->
    <delete id="deleteByIds">
        DELETE FROM salary WHERE id IN
        <foreach collection="ids" item="id" open="(" separator="," close=")">
            #{id}
        </foreach>
    </delete>

    <!-- 动态更新 -->
    <update id="update">
        UPDATE salary
        <set>
            <if test="salary.employeeId != null">
                employee_id = #{salary.employeeId},
            </if>
            <if test="salary.salaryAmount != null">
                salary_amount = #{salary.salaryAmount},
            </if>
            <if test="salary.payDate != null">
                pay_date = #{salary.payDate},
            </if>
            <if test="salary.payStatus != null">
                pay_status = #{salary.payStatus}
            </if>
        </set>
        WHERE id = #{salary.id}
    </update>

    <!-- 查询所有薪资记录 -->
    <select id="selectAll" resultMap="SalaryResultMap">
        SELECT * FROM salary ORDER BY id ASC
    </select>

    <!-- 多条件动态查询 -->
    <select id="selectMultiCondition" resultMap="SalaryResultMap">
        SELECT * FROM salary
        <where>
            <if test="salary.id != null">
                AND id = #{salary.id}
            </if>
            <if test="salary.employeeId != null">
                AND employee_id = #{salary.employeeId}
            </if>
            <if test="salary.salaryAmount != null">
                AND salary_amount = #{salary.salaryAmount}
            </if>
            <if test="salary.payDate != null">
                AND pay_date = #{salary.payDate}
            </if>
            <if test="salary.payStatus != null">
                AND pay_status = #{salary.payStatus}
            </if>
        </where>
    </select>
</mapper>