<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.tianshi.songzeyang.mapper.EmployeeMapper">
    <!-- 结果集映射 -->
    <resultMap id="EmployeeResultMap" type="Employee">
        <id column="id" property="id"/>
        <result column="emp_no" property="empNo"/>
        <result column="emp_name" property="empName"/>
        <result column="gender" property="gender"/>
        <result column="phone" property="phone"/>
        <result column="email" property="email"/>
        <result column="department_id" property="departmentId"/>
        <result column="status" property="status"/>
        <result column="hire_date" property="hireDate"/>
    </resultMap>

    <!-- 新增员工 -->
    <insert id="insert" useGeneratedKeys="true" keyProperty="emp.id">
        INSERT INTO employee (emp_no, emp_name, gender, phone, email, department_id, status, hire_date)
        VALUES (#{emp.empNo}, #{emp.empName}, #{emp.gender}, #{emp.phone}, #{emp.email}, #{emp.departmentId}, #{emp.status}, #{emp.hireDate})
    </insert>

    <!-- 根据ID删除员工 -->
    <delete id="deleteById">
        DELETE FROM employee WHERE id = #{id}
    </delete>

    <!-- 批量删除员工 -->
    <delete id="deleteByIds">
        DELETE FROM employee WHERE id IN
        <foreach collection="ids" item="id" open="(" separator="," close=")">
            #{id}
        </foreach>
    </delete>

    <!-- 多条件更新 -->
    <update id="update">
        UPDATE employee
        <set>
            <if test="emp.empNo != null and emp.empNo != ''">
                emp_no = #{emp.empNo},
            </if>
            <if test="emp.empName != null and emp.empName != ''">
                emp_name = #{emp.empName},
            </if>
            <if test="emp.gender != null">
                gender = #{emp.gender},
            </if>
            <if test="emp.phone != null and emp.phone != ''">
                phone = #{emp.phone},
            </if>
            <if test="emp.email != null and emp.email != ''">
                email = #{emp.email},
            </if>
            <if test="emp.departmentId != null">
                department_id = #{emp.departmentId},
            </if>
            <if test="emp.status != null">
                status = #{emp.status},
            </if>
            <if test="emp.hireDate != null">
                hire_date = #{emp.hireDate}
            </if>
        </set>
        WHERE id = #{emp.id}
    </update>

    <!-- 查询所有员工 -->
    <select id="selectAll" resultMap="EmployeeResultMap">
        SELECT * FROM employee ORDER BY id ASC
    </select>

    <!-- 多条件精确查询 -->
    <select id="selectMultiCondition" resultMap="EmployeeResultMap">
        SELECT * FROM employee
        <where>
            <if test="emp.id != null">
                AND id = #{emp.id}
            </if>
            <if test="emp.empNo != null and emp.empNo != ''">
                AND emp_no = #{emp.empNo}
            </if>
            <if test="emp.empName != null and emp.empName != ''">
                AND emp_name = #{emp.empName}
            </if>
            <if test="emp.gender != null">
                AND gender = #{emp.gender}
            </if>
            <if test="emp.phone != null and emp.phone != ''">
                AND phone = #{emp.phone}
            </if>
            <if test="emp.email != null and emp.email != ''">
                AND email = #{emp.email}
            </if>
            <if test="emp.departmentId != null">
                AND department_id = #{emp.departmentId}
            </if>
            <if test="emp.status != null">
                AND status = #{emp.status}
            </if>
        </where>
    </select>
</mapper>