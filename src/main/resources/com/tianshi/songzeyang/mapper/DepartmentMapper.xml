<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.tianshi.songzeyang.mapper.DepartmentMapper">

    <!-- 结果集映射 -->
    <resultMap id="DepartmentResultMap" type="Department">
        <id column="id" property="id"/>
        <result column="dept_name" property="deptName"/>
        <result column="manager_id" property="managerId"/>
        <result column="status" property="status"/>
        <result column="create_time" property="createTime"/>
    </resultMap>

    <!-- 新增部门 -->
    <insert id="insert" parameterType="Department" useGeneratedKeys="true" keyProperty="id">
        INSERT INTO department (dept_name, manager_id, status)
        VALUES (#{deptName}, #{managerId}, #{status})
    </insert>

    <!-- 根据ID删除部门 -->
    <delete id="deleteById" parameterType="Integer">
        DELETE FROM department WHERE id = #{id}
    </delete>

    <!-- 多条件更新 -->
    <update id="update" parameterType="Department">
        UPDATE department
        <set>
            <if test="deptName != null and deptName != ''">
                dept_name = #{deptName},
            </if>
            <if test="managerId != null">
                manager_id = #{managerId},
            </if>
            <if test="status != null">
                status = #{status}
            </if>
        </set>
        WHERE id = #{id}
    </update>

    <!-- 查询所有部门 -->
    <select id="selectAll" resultMap="DepartmentResultMap">
        SELECT * FROM department ORDER BY id ASC
    </select>

    <!-- 多条件精确查询 -->
    <select id="selectMultiCondition" parameterType="Department" resultMap="DepartmentResultMap">
        SELECT * FROM department
        <where>
            <if test="id != null">
                AND id = #{id}
            </if>
            <if test="deptName != null and deptName != ''">
                AND dept_name = #{deptName}
            </if>
            <if test="managerId != null">
                AND manager_id = #{managerId}
            </if>
            <if test="status != null">
                AND status = #{status}
            </if>
        </where>
    </select>

</mapper>