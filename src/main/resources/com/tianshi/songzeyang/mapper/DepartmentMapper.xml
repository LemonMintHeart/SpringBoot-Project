<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.tianshi.songzeyang.mapper.DepartmentMapper">
    <!-- 结果集映射 -->
    <resultMap id="DepartmentResultMap" type="Department">
        <id column="id" property="id"/>
        <result column="dept_name" property="deptName"/>
        <result column="manager_id" property="managerId"/>
        <result column="status" property="status"/>
        <result column="create_time" property="createTime"/>
    </resultMap>

    <!-- 新增部门 -->
    <insert id="insert" useGeneratedKeys="true" keyProperty="dept.id">
        INSERT INTO department (dept_name, manager_id, status)
        VALUES (#{dept.deptName}, #{dept.managerId}, #{dept.status})
    </insert>

    <!-- 根据ID删除部门 -->
    <delete id="deleteById">
        DELETE FROM department WHERE id = #{id}
    </delete>

    <!-- 多条件更新 -->
    <update id="update">
        UPDATE department
        <set>
            <if test="dept.deptName != null and dept.deptName != ''">
                dept_name = #{dept.deptName},
            </if>
            <if test="dept.managerId != null">
                manager_id = #{dept.managerId},
            </if>
            <if test="dept.status != null">
                status = #{dept.status}
            </if>
        </set>
        WHERE id = #{dept.id}
    </update>

    <!-- 查询所有部门 -->
    <select id="selectAll" resultMap="DepartmentResultMap">
        SELECT * FROM department ORDER BY id ASC
    </select>

    <!-- 多条件精确查询 -->
    <select id="selectMultiCondition" resultMap="DepartmentResultMap">
        SELECT * FROM department
        <where>
            <if test="dept.id != null">
                AND id = #{dept.id}
            </if>
            <if test="dept.deptName != null and dept.deptName != ''">
                AND dept_name = #{dept.deptName}
            </if>
            <if test="dept.managerId != null">
                AND manager_id = #{dept.managerId}
            </if>
            <if test="dept.status != null">
                AND status = #{dept.status}
            </if>
        </where>
    </select>
</mapper>